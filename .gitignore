# Couldnt find an official gitignore this is  AI generated
# -----------------------------
# Databricks / DAB / dbx
# -----------------------------
.databricks/          # local workspace metadata / CLI files
.deploy/              # local deploy cache (dbx/DAB)
.bundle/              # local bundle files (dbx/DAB)
*.log                 # temporary logs
*.tmp                 # temporary files
dbx_project.yaml.bak  # backup of bundle config
build/
dist/
tests/test-reports/*
# -----------------------------
# Python
# -----------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
env/
pip-selfcheck.json

# -----------------------------
# Jupyter Notebooks
# -----------------------------
# To stop printing of data resulting in it being in source control
.ipynb_checkpoints/
*-checkpoint.ipynb
*.log

# -----------------------------
# Scratch / experimental folder
# -----------------------------
scratch/**            # ignore all files in scratch
!scratch/README.md    # except placeholder README.md

# Ignore scratch notebooks
# so whenever you want to explore something you can do scratch-phil-ods-thingy and it wont be source controlled.
scratch-*.dbc
scratch-*.ipynb
scratch-*.py

## Data files (we may decide not to do this but will try it early on so its opt in)
*.csv
*.parquet
*.xlsx
## Databricks
.databricks/
*.dbc

# -----------------------------
# IDE / editor
# -----------------------------
.vscode/
.idea/

# -----------------------------
# OS / system
# -----------------------------
.DS_Store
Thumbs.db